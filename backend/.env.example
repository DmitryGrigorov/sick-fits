# PostgreSQL connection string (matches docker-compose.yml at the repo root)
DATABASE_URL="postgresql://sickfits:sickfits@localhost:5432/sickfits"

# Port the GraphQL API listens on
PORT=4444

# URL of the frontend app, used for CORS + password reset links
FRONTEND_URL="http://localhost:7777"

# Secret used to sign JSON Web Tokens — replace with a long random string
APP_SECRET="change-me-to-a-long-random-string"

# Stripe secret key (test mode) — https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET=""

# Outgoing mail (used for password reset emails). Mailtrap.io works well for local dev.
MAIL_HOST="smtp.mailtrap.io"
MAIL_PORT=2525
MAIL_USER=""
MAIL_PASS=""
